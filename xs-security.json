{
  "xsappname": "sap-copilot",
  "tenant-mode": "dedicated",
  "scopes": [
    {
      "name": "$XSAPPNAME.Intern",
      "description": "Intern access to basic features"
    },
    {
      "name": "$XSAPPNAME.Manager",
      "description": "Manager access with insights and decisions"
    },
    {
      "name": "$XSAPPNAME.Developer",
      "description": "Developer access with technical flow insights"
    }
  ],
  "role-templates": [
    {
      "name": "Intern",
      "description": "Intern Role",
      "scope-references": [
        "$XSAPPNAME.Intern"
      ]
    },
    {
      "name": "Manager",
      "description": "Manager Role",
      "scope-references": [
        "$XSAPPNAME.Manager"
      ]
    },
    {
      "name": "Developer",
      "description": "Developer Role",
      "scope-references": [
        "$XSAPPNAME.Developer"
      ]
    }
  ]
}
